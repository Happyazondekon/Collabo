rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.email == 'heyhappyproject@gmail.com';
    }

    function isCoupleMember(coupleId) {
      return isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }


    // ─── User profiles ────────────────────────────────────────────
    // Everyone authenticated can read (needed for partner look-up).
    // Each user writes their own document.
    // A partner can update coupleId/partnerUid/friendUids during linking.
    // Admin can list all users (dashboard).
    match /users/{userId} {
      allow read:   if isAuth();
      allow write:  if isAuth() && request.auth.uid == userId;
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['partnerUid', 'coupleId', 'friendUids']);
      allow list:   if isAdmin();
    }

    // ─── Couple rooms ────────────────────────────────────────────
    match /couples/{coupleId} {
      allow list: if isAdmin();
      allow read, write: if isAuth()
                         && request.auth.uid in resource.data.members;
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members.size() == 2;

      // ─── Chat messages ─────────────────────────────────────────
      match /messages/{messageId} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // ─── Stories / Notre Histoire ──────────────────────────────
      match /stories/{storyId} {
        allow read, write: if isCoupleMember(coupleId);
        match /comments/{commentId} {
          allow read, write: if isCoupleMember(coupleId);
        }
      }

      // ─── Calendar events ───────────────────────────────────────
      match /calendar_events/{eventId} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // ─── Gallery photos ────────────────────────────────────────
      match /gallery/{photoId} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // ─── Custom word lists ─────────────────────────────────────
      match /words/{wordId} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // ─── Remote games (competitive, timed, coop, crossword) ───
      match /games/{gameId} {
        allow read, write: if isCoupleMember(coupleId);
      }
    }

    // ─── Couple requests ─────────────────────────────────────────
    match /couple_requests/{requestId} {
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.fromUid;
      allow read: if isAuth()
                  && (request.auth.uid == resource.data.fromUid
                      || request.auth.token.email == resource.data.toEmail);
      allow update, delete: if isAuth()
                            && (request.auth.uid == resource.data.fromUid
                                || request.auth.token.email == resource.data.toEmail);
    }

    // ─── Direct message conversations ────────────────────────────
    match /conversations/{conversationId} {
      allow get: if isAuth()
                 && (resource == null || request.auth.uid in resource.data.members);
      allow list: if isAuth()
                  && request.auth.uid in resource.data.members;
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members.size() == 2;
      allow update, delete: if isAuth()
                            && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow read, write: if isAuth()
                           && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.members;
      }
    }

    // ─── Game sessions ────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read, write: if isAuth()
                         && request.auth.uid in resource.data.playerIds;
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.playerIds;
    }

    // ─── Achievements ─────────────────────────────────────────────
    match /achievements/{userId}/items/{achievementId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Calendar events (per-user, legacy path) ─────────────────
    match /calendar/{userId}/events/{eventId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Social feed ──────────────────────────────────────────────
    match /feed_posts/{postId} {
      // Anyone authenticated can read posts
      allow read: if isAuth();

      // Anyone authenticated can create their own post
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.authorUid;

      // Author deletes own post  OR  admin deletes any post
      allow delete: if isAuth()
                    && (request.auth.uid == resource.data.authorUid || isAdmin());

      // Likes, counters, flags — any authenticated user can update
      // Admin can also update (e.g. flagging)
      allow update: if isAuth();

      // Comments sub-collection
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth()
                      && request.auth.uid == request.resource.data.authorUid;
        allow delete: if isAuth()
                      && (request.auth.uid == resource.data.authorUid || isAdmin());
        allow update: if isAuth()
                      && (request.auth.uid == resource.data.authorUid || isAdmin());
      }
    }

    // ─── Reports ──────────────────────────────────────────────────
    // Any authenticated user can file a report.
    // Only admin can read all reports and update (resolve) or delete them.
    match /reports/{reportId} {
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.reportedBy;
      allow read, update, delete: if isAdmin();
    }

    // ─── WebRTC Calls ─────────────────────────────────────────────
    // Caller creates the document. Both caller and receiver can read/update
    // (to exchange offer/answer/status). ICE candidates are in sub-collections.
    match /calls/{callId} {
      // Caller can create the document
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.callerId;

      // Both parties can read and update (status, offer, answer)
      allow read, update: if isAuth()
                          && (request.auth.uid == resource.data.callerId
                              || request.auth.uid == resource.data.receiverId);

      // Either party can delete (clean-up after call ends)
      allow delete: if isAuth()
                    && (request.auth.uid == resource.data.callerId
                        || request.auth.uid == resource.data.receiverId);

      // ICE candidates from the caller
      match /callerCandidates/{candidateId} {
        allow read, create: if isAuth()
                            && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
                                || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
      }

      // ICE candidates from the receiver
      match /receiverCandidates/{candidateId} {
        allow read, create: if isAuth()
                            && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
                                || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
      }
    }

    // ─── Block all other paths ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

