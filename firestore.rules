rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profiles ──────────────────────────────────────────
    // Each user can only read/write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ─── User profiles ── extended ──────────────────────────────
    // Partners can update each other's coupleId/partnerUid during linking.
    match /users/{userId} {
      // Everyone authenticated can read profiles (needed to look up partner)
      allow read: if request.auth != null;

      // Users can write their own profile
      allow write: if request.auth != null
                   && request.auth.uid == userId;

      // A partner can update coupleId/partnerUid fields (accept/unlink flow)
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['partnerUid', 'coupleId']);
    }

    // ─── Couple rooms ────────────────────────────────────────────
    // Code writes field "members" (list of 2 uids). Only members can read/write.
    match /couples/{coupleId} {
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.members;

      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.members.size() == 2;

      // ─── Chat messages (sub-collection) ───────────────────────
      match /messages/{messageId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      // ─── Stories / Notre Histoire (sub-collection) ─────────────
      match /stories/{storyId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      // ─── Calendar events (sub-collection) ─────────────────────
      match /calendar_events/{eventId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      // ─── Gallery photos (sub-collection) ──────────────────────
      match /gallery/{photoId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      // ─── Words custom list (sub-collection) ───────────────────
      match /words/{wordId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }
    }

    // ─── Couple requests ─────────────────────────────────────────
    // Sender creates and reads. Recipient reads (by email) and updates.
    match /couple_requests/{requestId} {
      // Sender can create their own request
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid;

      // Sender can read their outgoing requests
      // Recipient can read requests addressed to their email
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromUid
                      || request.auth.token.email == resource.data.toEmail);

      // Either party can update (accept / decline / cancel)
      allow update, delete: if request.auth != null
                            && (request.auth.uid == resource.data.fromUid
                                || request.auth.token.email == resource.data.toEmail);
    }

    // ─── Game sessions ───────────────────────────────────────────
    // A session stores playerIds (list of uids who played).
    // Only those players can read/write the session.
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.playerIds;

      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.playerIds;
    }

    // ─── Achievements ────────────────────────────────────────────
    // Stored per-user under /achievements/{userId}/items/{achievementId}
    match /achievements/{userId}/items/{achievementId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ─── Calendar events ────────────────────────────────────────
    // Stored per-user: /calendar/{userId}/events/{eventId}
    match /calendar/{userId}/events/{eventId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Block all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
